{
  "name": "aiqlick-meeting",
  "version": "1.0.0",
  "description": "Aiqlick meeting client — Expo + React Native + Tamagui app that embeds the Jitsi conference via the IFrame API on web and the native Jitsi SDK on mobile.",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web --output-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@jitsi/react-native-sdk": "^0.5.0",
    "@tamagui/animations-react-native": "^1.119.0",
    "@tamagui/config": "^1.119.0",
    "@tamagui/font-inter": "^1.119.0",
    "@tamagui/lucide-icons": "^1.119.0",
    "@tamagui/themes": "^1.119.0",
    "expo": "~52.0.20",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.14",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "tamagui": "^1.119.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@tamagui/babel-plugin": "^1.119.0",
    "@types/react": "~18.3.12",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "typescript": "~5.3.3"
  }
}
